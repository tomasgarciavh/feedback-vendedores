# ============================================================
# Sistema de Feedback Automático de Videos de Ventas
# Copia este archivo a .env y completá los valores
# ============================================================

# ------------------------------------------------------------
# Gemini (análisis de video + generación de feedback)
# ------------------------------------------------------------

# Tu clave de API de Google Gemini.
# Obtén una en https://aistudio.google.com/
GEMINI_API_KEY=

# Modelo a usar. gemini-2.0-flash es más rápido y económico.
# Opciones: gemini-2.0-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# Gmail (envío de emails de feedback)
# ------------------------------------------------------------

# Tu dirección de Gmail desde la que se enviarán los emails.
GMAIL_USER=tu_correo@gmail.com

# Contraseña de aplicación de Gmail (NO es tu contraseña normal).
# Para generarla: Google Account → Seguridad → Verificación en 2 pasos
# → Contraseñas de aplicación → Correo / Otro dispositivo.
GMAIL_APP_PASSWORD=

# ------------------------------------------------------------
# Identidad
# ------------------------------------------------------------

# Tu nombre, para firmar los emails de feedback.
YOUR_NAME=Tu nombre

# Idioma del feedback generado.
# Opciones: español, english, português
FEEDBACK_LANGUAGE=español

# ------------------------------------------------------------
# Configuración opcional
# ------------------------------------------------------------

# Tamaño máximo de archivo en MB (default: 500)
MAX_UPLOAD_MB=500

# Criterios de evaluación personalizados (opcional).
# Si no se define, se usa un conjunto predeterminado sobre técnica de ventas.
# FEEDBACK_CRITERIA=
